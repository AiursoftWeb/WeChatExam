@using System.Text.Json
@model Aiursoft.WeChatExam.Models.AccountingViewModels.IndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Finance Reports"]</h3>
    </div>
</div>

<div class="row">
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col mt-0">
                        <h5 class="card-title">@Localizer["Total Users"]</h5>
                    </div>
                    <div class="col-auto">
                        <div class="stat text-primary">
                            <i class="align-middle" data-lucide="users"></i>
                        </div>
                    </div>
                </div>
                <h1 class="mt-1 mb-3">@Model.TotalUsers</h1>
                <div class="mb-0">
                    <span class="text-success"> <i class="mdi mdi-arrow-bottom-right"></i> @Model.NewUsersLast30Days </span>
                    <span class="text-muted">@Localizer["New in 30 days"]</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col mt-0">
                        <h5 class="card-title">@Localizer["Active VIPs"]</h5>
                    </div>
                    <div class="col-auto">
                        <div class="stat text-primary">
                            <i class="align-middle" data-lucide="award"></i>
                        </div>
                    </div>
                </div>
                <h1 class="mt-1 mb-3">@Model.ActivePaidUsers</h1>
                <div class="mb-0">
                    <span class="text-success"> <i class="mdi mdi-arrow-bottom-right"></i> @Model.NewVipActivationsLast30Days </span>
                    <span class="text-muted">@Localizer["New in 30 days"]</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-8">
        <div class="card flex-fill w-100">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Recent Movement"]</h5>
            </div>
            <div class="card-body py-3">
                <div class="chart chart-sm">
                    <canvas id="accounting-chart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title">@Localizer["Monthly Statistics"]</h5>
        <h6 class="card-subtitle text-muted">@Localizer["Monthly count of users who activated any VIP membership."]</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
            <tr>
                <th>@Localizer["Month"]</th>
                <th>@Localizer["Active Paid Users"]</th>
                <th class="text-end">@Localizer["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var report in Model.Reports)
            {
                <tr>
                    <td>@report.Month.ToString("MMMM yyyy")</td>
                    <td>
                        <span class="badge bg-success">@report.ActiveUsers.Select(u => u.User.Id).Distinct().Count()</span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-month="@report.Month.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-primary">
                            <i class="align-middle" data-lucide="eye"></i> @Localizer["Details"]
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        new Chart(document.getElementById("accounting-chart"), {
            type: "line",
            data: {
                labels: @Html.Raw(JsonSerializer.Serialize(Model.ChartLabels)),
                datasets: [{
                    label: "@Localizer["New Users"]",
                    fill: true,
                    backgroundColor: "transparent",
                    borderColor: window.theme.primary,
                    data: @JsonSerializer.Serialize(Model.NewUsersData)
                }, {
                    label: "@Localizer["New VIPs"]",
                    fill: true,
                    backgroundColor: "transparent",
                    borderColor: window.theme.tertiary,
                    borderDash: [4, 4],
                    data: @JsonSerializer.Serialize(Model.NewVipData)
                }]
            },
            options: {
                maintainAspectRatio: false,
                legend: {
                    display: false
                },
                tooltips: {
                    intersect: false
                },
                hover: {
                    intersect: true
                },
                plugins: {
                    filler: {
                        propagate: false
                    }
                },
                scales: {
                    xAxes: [{
                        reverse: true,
                        gridLines: {
                            color: "rgba(0,0,0,0.05)"
                        }
                    }],
                    yAxes: [{
                        ticks: {
                            stepSize: 500
                        },
                        display: true,
                        borderDash: [5, 5],
                        gridLines: {
                            color: "rgba(0,0,0,0)",
                            fontColor: "#fff"
                        }
                    }]
                }
            }
        });
    });
</script>
