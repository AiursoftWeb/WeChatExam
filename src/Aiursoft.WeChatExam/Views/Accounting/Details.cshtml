@using Aiursoft.WebTools
@using Aiursoft.WeChatExam.Entities
@model Aiursoft.WeChatExam.Models.AccountingViewModels.DetailsViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Finance Report Details"] - @Model.Report.Month.ToString("MMMM yyyy")</h3>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title">@Localizer["VIP Activation Events"]</h5>
        <h6 class="card-subtitle text-muted">@Localizer["List of all VIP activations that occurred in this month."]</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
            <tr>
                <th>@Localizer["User"]</th>
                <th>@Localizer["Product"]</th>
                <th>@Localizer["Method"]</th>
                <th>@Localizer["Activation Time"]</th>
                <th>@Localizer["Details"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var detail in Model.Report.ActiveUsers)
            {
                <tr>
                    <td>
                        <div class="fw-bold">@detail.User.DisplayName</div>
                        <div class="small text-muted">@detail.User.UserName</div>
                    </td>
                    <td>
                        @(detail.ActivationEvent.VipProduct?.Name ?? "Unknown")
                    </td>
                    <td>
                        @switch (detail.ActivationEvent.Type)
                        {
                            case ChangeType.VipActivatedViaPayment:
                                <span class="badge bg-success">@Localizer["Payment"]</span>
                                break;
                            case ChangeType.VipActivatedViaCoupon:
                                <span class="badge bg-info">@Localizer["Coupon"]</span>
                                break;
                            case ChangeType.VipActivatedViaAdmin:
                                <span class="badge bg-warning">@Localizer["Admin"]</span>
                                break;
                            default:
                                <span class="badge bg-secondary">@detail.ActivationEvent.Type</span>
                                break;
                        }
                    </td>
                    <td>
                        <label data-utc-time="@detail.ActivationEvent.CreateTime.ToHtmlDateTime()"></label>
                    </td>
                    <td class="small">
                        @detail.ActivationEvent.Details
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="align-middle" data-lucide="arrow-left"></i> @Localizer["Back to Reports"]
    </a>
</div>
