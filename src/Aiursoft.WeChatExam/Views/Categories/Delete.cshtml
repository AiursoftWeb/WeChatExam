@model Aiursoft.WeChatExam.Models.CategoriesViewModels.DeleteViewModel

<h1 class="h3 mb-3">@Localizer["Delete Category"]</h1>
<div class="card">
    <div class="card-body text-center">
        <i class="align-middle text-danger" data-lucide="trash-2" style="width: 48px; height: 48px;"></i>
        <h2 class="h4 card-title fw-bold">@Localizer["Are you sure?"]</h2>
        <p class="mb-3 text-muted">@Localizer["This action is irreversible. You are about to permanently delete the following category:"]</p>
        <div class="d-inline-block bg-body-tertiary rounded p-2 px-3 mb-4">
            <strong class="fs-5">@Model.Category.Title</strong>
        </div>
        @if (Model.HasChildren || Model.HasQuestions)
        {
            <div class="alert alert-warning" role="alert">
                <div class="alert-icon">
                    <i data-lucide="alert-triangle"></i>
                </div>
                <div class="alert-message">
                    @if (Model.HasChildren)
                    {
                        <p class="mb-1">@Localizer["Cannot delete category with children. Please delete children first."]</p>
                    }
                    @if (Model.HasQuestions)
                    {
                        <p class="mb-1">@Localizer["Cannot delete category with associated questions. Please remove or reassign these questions first."]</p>
                        <a asp-controller="Questions" asp-action="Index" asp-route-categoryId="@Model.Category.Id" class="btn btn-sm btn-warning mt-2">
                            <i class="align-middle me-1" data-lucide="external-link"></i> @Localizer["View related questions"]
                        </a>
                    }
                </div>
            </div>
            <a asp-action="Index" class="btn btn-light">@Localizer["Back to List"]</a>
        }
        else
        {
            <form asp-action="Delete" asp-route-id="@Model.Category.Id" method="post" class="d-inline-block">
                <button type="submit" class="btn btn-danger">
                    <i class="align-middle me-2" data-lucide="trash-2"></i> @Localizer["Yes, delete this category"]
                </button>
            </form>
            <a asp-action="Index" class="btn btn-light">@Localizer["Cancel"]</a>
        }
    </div>
</div>
