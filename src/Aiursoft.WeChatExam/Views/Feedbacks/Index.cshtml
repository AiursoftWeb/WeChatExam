@using Aiursoft.WeChatExam.Entities
@using Aiursoft.WebTools
@model Aiursoft.WeChatExam.Models.FeedbacksViewModels.IndexViewModel

<div class="row mb-3">
    <div class="col-12">
        <h1 class="h3 mb-0">@Localizer["User Feedbacks"]</h1>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">@Localizer["Status"]</label>
                <select name="status" class="form-select" onchange="this.form.submit()">
                    <option value="">@Localizer["All Status"]</option>
                    <option value="0" selected="@(Model.StatusFilter == FeedbackStatus.Pending)">@Localizer["Pending"]</option>
                    <option value="1" selected="@(Model.StatusFilter == FeedbackStatus.Processed)">@Localizer["Processed"]</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Type"]</label>
                <select name="type" class="form-select" onchange="this.form.submit()">
                    <option value="">@Localizer["All Types"]</option>
                    @foreach (var type in Enum.GetValues<FeedbackType>())
                    {
                        <option value="@((int)type)" selected="@(Model.TypeFilter == type)">@Localizer[type.GetDisplayName()]</option>
                    }
                </select>
            </div>
            <div class="col-md-6 text-end d-flex align-items-end justify-content-end">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary me-2">@Localizer["Reset"]</a>
                <button type="submit" class="btn btn-primary">@Localizer["Filter"]</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>@Localizer["User"]</th>
                    <th>@Localizer["Type"]</th>
                    <th>@Localizer["Content"]</th>
                    <th>@Localizer["Contact"]</th>
                    <th>@Localizer["Status"]</th>
                    <th>@Localizer["Created At"]</th>
                    <th class="text-end">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var feedback in Model.Feedbacks)
                {
                    <tr>
                        <td>
                            @if (feedback.User != null)
                            {
                                <a asp-controller="Users" asp-action="Details" asp-route-id="@feedback.UserId">
                                    @feedback.User.DisplayName
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">@Localizer["Unknown User"] (@feedback.UserId)</span>
                            }
                        </td>
                        <td>@Localizer[feedback.Type.GetDisplayName()]</td>
                        <td style="max-width: 400px; white-space: pre-wrap;">@feedback.Content</td>
                        <td>@feedback.Contact</td>
                        <td>
                            @if (feedback.Status == FeedbackStatus.Pending)
                            {
                                <span class="badge bg-warning">@Localizer["Pending"]</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@Localizer["Processed"]</span>
                            }
                        </td>
                        <td>@feedback.CreatedAt.ToHtmlDateTime()</td>
                        <td class="text-end">
                            <div class="btn-group">
                                @if (feedback.Status == FeedbackStatus.Pending)
                                {
                                    <form asp-action="Process" asp-route-id="@feedback.Id" method="post" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            <i class="align-middle" data-lucide="check-circle"></i> @Localizer["Mark as Processed"]
                                        </button>
                                    </form>
                                }
                                <a asp-action="Delete" asp-route-id="@feedback.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="align-middle" data-lucide="trash-2"></i> @Localizer["Delete"]
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Feedbacks.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            @Localizer["No feedbacks found."]
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalCount > Model.PageSize)
    {
        <div class="card-footer">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    @{
                        var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
                        foreach (var i in Enumerable.Range(1, totalPages))
                        {
                            <li class="page-item @(Model.Page == i ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-status="@Model.StatusFilter" asp-route-type="@Model.TypeFilter">@i</a>
                            </li>
                        }
                    }
                </ul>
            </nav>
        </div>
    }
</div>
