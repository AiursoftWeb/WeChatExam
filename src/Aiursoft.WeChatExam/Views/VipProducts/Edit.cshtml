@model Aiursoft.WeChatExam.Models.VipProductsViewModels.EditViewModel
@using Aiursoft.WeChatExam.Entities

<h1 class="h3 mb-3">@Localizer["Edit VIP Product"]</h1>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label">@Localizer["Product Name"]</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Type" class="form-label">@Localizer["VIP Type"]</label>
                <select asp-for="Type" class="form-select" id="vipTypeSelect">
                    <option value="@((int)VipProductType.Category)">@Localizer["Category VIP"]</option>
                    <option value="@((int)VipProductType.RealExam)">@Localizer["Real Exam VIP"]</option>
                </select>
            </div>
            <div class="mb-3" id="categorySection">
                <label asp-for="CategoryId" class="form-label">@Localizer["Category"]</label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                    <option value="">@Localizer["-- Select Category --"]</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="PriceInFen" class="form-label">@Localizer["Price (Fen)"]</label>
                    <div class="input-group">
                        <input asp-for="PriceInFen" class="form-control" type="number" min="1" />
                        <span class="input-group-text">@Localizer["Fen (1/100 Yuan)"]</span>
                    </div>
                    <span asp-validation-for="PriceInFen" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="DurationDays" class="form-label">@Localizer["Duration (Days)"]</label>
                    <div class="input-group">
                        <input asp-for="DurationDays" class="form-control" type="number" min="1" />
                        <span class="input-group-text">@Localizer["Days"]</span>
                    </div>
                    <span asp-validation-for="DurationDays" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="IsEnabled" class="form-check-input" type="checkbox" />
                    <label asp-for="IsEnabled" class="form-check-label">@Localizer["Enabled"]</label>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="align-middle me-1" data-lucide="save"></i> @Localizer["Save"]
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var typeSelect = document.getElementById('vipTypeSelect');
        var categorySection = document.getElementById('categorySection');

        function toggleCategory() {
            var isCategory = typeSelect.value === '@((int)VipProductType.Category)';
            categorySection.style.display = isCategory ? '' : 'none';
            if (!isCategory) {
                var categorySelect = document.getElementById('CategoryId');
                if (categorySelect) categorySelect.value = '';
            }
        }

        typeSelect.addEventListener('change', toggleCategory);
        toggleCategory();
    });
</script>
