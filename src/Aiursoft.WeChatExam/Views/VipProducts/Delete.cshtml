@model Aiursoft.WeChatExam.Models.VipProductsViewModels.DeleteViewModel

<h1 class="h3 mb-3">@Localizer["Delete VIP Product"]</h1>

<div class="card">
    <div class="card-body">
        <div class="alert alert-danger">
            <i class="align-middle me-1" data-lucide="alert-triangle"></i>
            @Localizer["Are you sure you want to delete this VIP product? This action cannot be undone."]
        </div>

        <table class="table table-borderless mb-3">
            <tbody>
                <tr>
                    <th style="width:200px">@Localizer["Name"]</th>
                    <td><strong>@Model.Product.Name</strong></td>
                </tr>
                <tr>
                    <th>@Localizer["Category"]</th>
                    <td><span class="badge bg-info">@(Model.Product.Category?.Title ?? "-")</span></td>
                </tr>
                <tr>
                    <th>@Localizer["Price"]</th>
                    <td>¥@((Model.Product.PriceInFen / 100.0).ToString("F2"))</td>
                </tr>
                <tr>
                    <th>@Localizer["Duration"]</th>
                    <td>@Model.Product.DurationDays @Localizer["days"]</td>
                </tr>
                <tr>
                    <th>@Localizer["Status"]</th>
                    <td>
                        @if (Model.Product.IsEnabled)
                        {
                            <span class="badge bg-success">@Localizer["Enabled"]</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Localizer["Disabled"]</span>
                        }
                    </td>
                </tr>
            </tbody>
        </table>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Product.Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="align-middle me-1" data-lucide="trash-2"></i> @Localizer["Delete"]
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
