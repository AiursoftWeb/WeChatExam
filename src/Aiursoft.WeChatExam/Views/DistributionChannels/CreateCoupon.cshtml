@model Aiursoft.WeChatExam.Models.DistributionChannelsViewModels.CreateCouponViewModel

<h1 class="h3 mb-3">@Localizer["Create Coupon for {0}", Model.ChannelName ?? "Channel"]</h1>

<div class="card">
    <div class="card-body">
        <form asp-action="CreateCoupon" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ChannelId" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" placeholder="e.g. SAVE30" />
                <span asp-validation-for="Code" class="text-danger"></span>
                <div class="form-text">@Localizer["Unique code for users to enter."]</div>
            </div>

            <div class="mb-3">
                <label asp-for="AmountInFen" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="AmountInFen" type="number" min="0" step="1" class="form-control" placeholder="e.g. 1000 for 10.00 CNY" />
                    <span class="input-group-text">@Localizer["Fen"]</span>
                </div>
                <span asp-validation-for="AmountInFen" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsSingleUse" class="form-check-input" />
                <label asp-for="IsSingleUse" class="form-check-label"></label>
                <div class="form-text">@Localizer["If checked, this coupon can only be used once (e.g. for a specific student)."]</div>
            </div>

            <div class="mb-3">
                <label class="form-label">@Localizer["Applicable Products (Empty for all)"]</label>
                <div class="row row-cols-1 row-cols-md-2 g-2">
                    @foreach (var product in Model.AvailableVipProducts)
                    {
                        <div class="col">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="TargetVipProductIds" value="@product.Id" id="prod_@product.Id" @(Model.TargetVipProductIds?.Contains(product.Id) == true ? "checked" : "")>
                                <label class="form-check-label" for="prod_@product.Id">
                                    @product.Name (¥@(product.PriceInFen / 100.0))
                                </label>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i data-lucide="save"></i> @Localizer["Create Coupon"]
                </button>
                <a asp-action="Details" asp-route-id="@Model.ChannelId" class="btn btn-secondary">
                    @Localizer["Cancel"]
                </a>
            </div>
        </form>
    </div>
</div>
