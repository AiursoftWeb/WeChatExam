@using Aiursoft.WebTools
@using Aiursoft.WeChatExam.Services.FileStorage
@inject StorageService StorageService
@model Aiursoft.WeChatExam.Models.VipMembersViewModels.IndexViewModel
<style>
    .clickable-row {
        cursor: pointer;
    }
</style>

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>
            @if (Model.TargetUser != null)
            {
                @Localizer["Manage VIP Members for: "] <span class="text-muted">@Model.TargetUser.DisplayName</span>
            }
            else
            {
                @Localizer["Manage VIP Members"]
            }
        </h3>
    </div>

    <div class="col-auto ms-auto mt-n1">
        <a asp-action="Create" asp-route-userId="@Model.UserId" class="btn btn-primary">
            <i class="align-middle" data-lucide="plus"></i> @Localizer["Create a new VIP membership"]
        </a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header cursor-pointer" data-bs-toggle="collapse" data-bs-target="#filterPanel">
        <h5 class="card-title mb-0 d-flex justify-content-between">
            <span><i class="align-middle me-2" data-lucide="filter"></i> @Localizer["Filters & Search"]</span>
            <i class="align-middle" data-lucide="chevron-down"></i>
        </h5>
    </div>
    <div id="filterPanel" class="collapse show">
        <div class="card-body">
            <form asp-action="Index" method="get" id="filterForm">
                <input type="hidden" name="userId" value="@Model.UserId" />
                <input type="hidden" name="page" id="pageInput" value="1" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">@Localizer["Search Keyword"]</label>
                        <input type="text" name="search" value="@Model.SearchQuery" class="form-control" placeholder="@Localizer["Search by User or Product Name..."]" />
                    </div>
                    <div class="col-md-3">
                         <label class="form-label">@Localizer["Items per page"]</label>
                         <select name="pageSize" class="form-select" onchange="this.form.submit()">
                             <option value="15" selected="@(Model.PageSize == 15)">15</option>
                             <option value="30" selected="@(Model.PageSize == 30)">30</option>
                             <option value="50" selected="@(Model.PageSize == 50)">50</option>
                             <option value="100" selected="@(Model.PageSize == 100)">100</option>
                         </select>
                    </div>

                    <div class="col-12 text-end">
                        <a href="@Url.Action("Index", new { userId = Model.UserId })" class="btn btn-outline-secondary me-2">@Localizer["Reset"]</a>
                        <button type="submit" class="btn btn-primary" onclick="document.getElementById('pageInput').value = '1';">@Localizer["Apply Filters"]</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title">@Localizer["VIP Memberships"]</h5>
        <h6 class="card-subtitle text-muted">@Localizer["A list of all VIP memberships in the system."]</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
            <tr>
                <th>@Localizer["User"]</th>
                <th>@Localizer["Product"]</th>
                <th>@Localizer["Start Time"]</th>
                <th>@Localizer["End Time"]</th>
                <th>@Localizer["Is Active"]</th>
                <th class="text-end">@Localizer["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.VipMembers)
            {
                <tr class="clickable-row" data-href="@Url.Action("Edit", new { id = item.Id })">
                    <td>
                        @if (item.User != null)
                        {
                            <img src="@StorageService.RelativePathToInternetUrl(item.User.AvatarRelativePath)?w=36&square=true" alt="@item.User.DisplayName" class="rounded-circle me-2" width="24" height="24" />
                            @item.User.DisplayName
                        }
                    </td>
                    <td>@(item.VipProduct?.Name)</td>
                    <td>
                        <label data-utc-time="@item.StartTime.ToHtmlDateTime()" class="text-monospace"></label>
                    </td>
                    <td>
                        <label data-utc-time="@item.EndTime.ToHtmlDateTime()" class="text-monospace"></label>
                    </td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">@Localizer["Active"]</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@Localizer["Expired"]</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                            <i class="align-middle" data-lucide="edit-2"></i> @Localizer["Edit"]
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                            <i class="align-middle" data-lucide="trash-2"></i> @Localizer["Delete"]
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.VipMembers.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        <i class="align-middle mb-2" data-lucide="inbox" style="width: 32px; height: 32px;"></i><br/>
                        @Localizer["No VIP memberships found"]
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer py-3">
            <div class="d-flex flex-wrap justify-content-center align-items-center gap-3">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" href="javascript:void(0)" onclick="changePage(@(Model.CurrentPage - 1))">@Localizer["Previous"]</a>
                        </li>

                        @{
                            var startPage = Math.Max(1, Model.CurrentPage - 5);
                            var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 5);

                            if (startPage > 1)
                            {
                                <li class="page-item"><a class="page-link" href="javascript:void(0)" onclick="changePage(1)">1</a></li>
                                if(startPage > 2) { <li class="page-item disabled"><span class="page-link">...</span></li> }
                            }

                            for (var i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                    <a class="page-link" href="javascript:void(0)" onclick="changePage(@i)">@i</a>
                                </li>
                            }

                            if (endPage < Model.TotalPages)
                            {
                                if(endPage < Model.TotalPages - 1) { <li class="page-item disabled"><span class="page-link">...</span></li> }
                                <li class="page-item"><a class="page-link" href="javascript:void(0)" onclick="changePage(@Model.TotalPages)">@Model.TotalPages</a></li>
                            }
                        }

                        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="javascript:void(0)" onclick="changePage(@(Model.CurrentPage + 1))">@Localizer["Next"]</a>
                        </li>
                    </ul>
                </nav>

                <div class="input-group input-group-sm" style="width: 110px;">
                    <input type="number" id="jumpToPageInput" class="form-control" min="1" max="@Model.TotalPages" value="@Model.CurrentPage" onkeypress="if(event.keyCode==13) jumpToPage()">
                    <button class="btn btn-outline-primary" type="button" onclick="jumpToPage()">@Localizer["Go"]</button>
                </div>
            </div>
            <div class="text-center mt-2 text-muted small">
                @Localizer["Showing"] @((Model.CurrentPage - 1) * Model.PageSize + 1) @Localizer["to"] @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount) @Localizer["of"] @Model.TotalCount @Localizer["items"]
            </div>
        </div>
    }
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rows = document.querySelectorAll(".clickable-row");
            rows.forEach(row => {
                row.addEventListener("click", function (event) {
                    const target = event.target;
                    if (!target.matches('a, a *, button, button *, input, select')) {
                        window.location.href = row.dataset.href;
                    }
                });
            });
        });

        function changePage(page) {
            document.getElementById('pageInput').value = page;
            document.getElementById('filterForm').submit();
        }

        function jumpToPage() {
            var page = document.getElementById('jumpToPageInput').value;
            if (page) {
                changePage(page);
            }
        }
    </script>
}