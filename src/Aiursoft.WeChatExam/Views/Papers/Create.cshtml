@model Aiursoft.WeChatExam.Models.PapersViewModels.CreateViewModel

<h1 class="h3 mb-3">@Localizer["Create Paper"]</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="card mb-3">
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="Title" class="form-label">@Localizer["Title"]</label>
                <input asp-for="Title" class="form-control" required />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TimeLimit" class="form-label">@Localizer["Time Limit (minutes)"]</label>
                <input asp-for="TimeLimit" type="number" class="form-control" min="1" />
                <span asp-validation-for="TimeLimit" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SelectedCategoryId" class="form-label">@Localizer["Category"]</label>
                <select asp-for="SelectedCategoryId" asp-items="Model.AvailableCategories" class="form-select">
                    <option value="">@Localizer["-- Select Category (Optional) --"]</option>
                </select>
                <span asp-validation-for="SelectedCategoryId" class="text-danger"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsFree" class="form-check-input" type="checkbox" />
                <label asp-for="IsFree" class="form-check-label">@Localizer["Free Paper"]</label>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsRealExam" class="form-check-input" type="checkbox" />
                <label asp-for="IsRealExam" class="form-check-label">@Localizer["Real Exam"]</label>
            </div>
            <div class="mb-3">
                <label class="form-label">@Localizer["Tags"]</label>
                <input type="text" id="tagInputField" class="form-control" placeholder="@Localizer["Type to search or add tags..."]" autocomplete="off" />
                <input type="hidden" asp-for="Tags" id="Tags" />
                <small class="form-text text-muted">@Localizer["Press Enter to add a tag, or select from suggestions. Click X to remove."]</small>
            </div>
        </div>
        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary">@Localizer["Create"]</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">@Localizer["Cancel"]</a>
        </div>
    </div>
</form>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script src="~/js/tag-input.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Tags Init
            const tagInput = document.getElementById('tagInputField');
            const tagHidden = document.getElementById('Tags');
            const initialTags = @Json.Serialize(Model.Tags?.Split(' ', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>());
            TagInput.init(tagInput, tagHidden, initialTags);
        });
    </script>
}
